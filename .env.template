# AI Harness — Local Development Environment Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to source control.

# ──────────────────────────────────────────────────────────
# Anthropic
# ──────────────────────────────────────────────────────────
Anthropic__ApiKey=sk-ant-...

# ──────────────────────────────────────────────────────────
# Azure Cosmos DB (local: use emulator defaults)
# ──────────────────────────────────────────────────────────
CosmosDb__AccountEndpoint=https://localhost:8081

# ──────────────────────────────────────────────────────────
# Azure Service Bus (local: use Azurite or a dev namespace)
# ──────────────────────────────────────────────────────────
ServiceBus__FullyQualifiedNamespace=<namespace>.servicebus.windows.net

# ──────────────────────────────────────────────────────────
# Azure Blob Storage (local: use Azurite default)
# ──────────────────────────────────────────────────────────
BlobStorage__AccountUri=http://127.0.0.1:10000/devstoreaccount1

# ──────────────────────────────────────────────────────────
# GitHub integration (optional for local dev)
# ──────────────────────────────────────────────────────────
GitHub__Token=ghp_...
GitHub__Owner=<org-or-user>
GitHub__Repo=<repo-name>
GitHub__DefaultBranch=main

# ──────────────────────────────────────────────────────────
# Key Vault (skipped in Development environment)
# ──────────────────────────────────────────────────────────
# KeyVault__Uri=https://<vault-name>.vault.azure.net/
